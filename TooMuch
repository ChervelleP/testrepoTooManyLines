section .data
    msg1 db "Starting program...", 10
    len1 equ $ - msg1

    msg2 db "Counting from 1 to 5:", 10
    len2 equ $ - msg2

    msg_done db "Done!", 10
    len_done equ $ - msg_done

    newline db 10

section .bss
    buffer resb 2        ; for single digit + newline

section .text
    global _start

_start:

    ; print msg1
    mov rax, 1
    mov rdi, 1
    mov rsi, msg1
    mov rdx, len1
    syscall

    ; print msg2
    mov rax, 1
    mov rdi, 1
    mov rsi, msg2
    mov rdx, len2
    syscall

    ; initialize counter
    mov rcx, 1

count_loop:

    ; convert number to ASCII
    mov rax, rcx
    add rax, '0'
    mov [buffer], al

    ; newline
    mov byte [buffer + 1], 10

    ; print number
    mov rax, 1
    mov rdi, 1
    mov rsi, buffer
    mov rdx, 2
    syscall

    ; increment counter
    inc rcx

    ; loop until 5
    cmp rcx, 6
    jne count_loop

    ; print done message
    mov rax, 1
    mov rdi, 1
    mov rsi, msg_done
    mov rdx, len_done
    syscall

    ; extra no-op section to increase line count
    mov rbx, 0
    mov rbx, rbx
    mov rbx, rbx
    mov rbx, rbx
    mov rbx, rbx
    mov rbx, rbx
    mov rbx, rbx
    mov rbx, rbx
    mov rbx, rbx
    mov rbx, rbx

    mov rdx, 0
    mov rdx, rdx
    mov rdx, rdx
    mov rdx, rdx
    mov rdx, rdx
    mov rdx, rdx
    mov rdx, rdx
    mov rdx, rdx
    mov rdx, rdx
    mov rdx, rdx

    ; exit
    mov rax, 60
    xor rdi, rdi
    syscall
